# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rfpilot

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# OpenAI API key
OPENAI_API_KEY=sk-...

APP_NAME=RFPilot
APP_ENV=development
APP_DEBUG=true

# ── Email (optional — leave blank to use console-only mode) ───────────────────
# Configure any SMTP provider (Gmail, Resend, Postmark, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rfpilot.com

# Frontend base URL (used to build invite links)
FRONTEND_URL=http://localhost:3001
